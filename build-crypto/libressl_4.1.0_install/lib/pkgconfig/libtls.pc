prefix=/home/jlind/dev/vio/build-crypto/libressl_4.1.0_install
exec_prefix=${prefix}
libdir=${exec_prefix}/lib
includedir=${prefix}/include

Name: LibreSSL-libtls
Description: Secure communications using the TLS socket protocol.
Version: 4.1.0
Libs: -L${libdir} -ltls
Libs.private:   -lpthread -lrt -lssl -lcrypto
Cflags: -I${includedir}
